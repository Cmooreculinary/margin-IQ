# Path to the SQLite database file (created on first run; parent dirs are created too)
SQLITE_PATH=margin_iq.db
ANTHROPIC_API_KEY=
DEFAULT_RECONCILIATION_TOLERANCE_PCT=2.0
# Seed the Rook & Roast demo tenant on startup if the database is empty
SEED_DEMO=false
# Comma-separated origins allowed by CORS (only needed for split dev servers)
CORS_ORIGINS=http://localhost:5173
